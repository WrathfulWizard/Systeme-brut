{
  "name": "ashbound",
  "version": "0.0.1",
  "private": true,
  "description": "Ashbound — a top-down 2.5D pixel-art soulslike (Mac/Windows desktop)",
  "main": "dist/electron/main.js",
  "scripts": {
    "build:renderer": "esbuild src/main.ts --bundle --outfile=dist/renderer/bundle.js --platform=browser --format=iife --loader:.png=dataurl",
    "build:main": "esbuild electron/main.ts electron/preload.ts --bundle --outdir=dist/electron --platform=node --external:electron --format=cjs",
    "build": "npm run build:renderer && npm run build:main && node scripts/copy-static.cjs",
    "start": "npm run build && electron .",
    "smoke": "node scripts/smoke.cjs",
    "smoke:runtime": "npm run build && ASHBOUND_SMOKE=1 electron .",
    "typecheck": "tsc --noEmit",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:win": "npm run build && electron-builder --win"
  },
  "build": {
    "appId": "com.ashbound.game",
    "productName": "Ashbound",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.games"
    },
    "win": {
      "target": "nsis"
    }
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.24.0",
    "typescript": "^5.6.0"
  },
  "dependencies": {
    "phaser": "^3.87.0"
  }
}
